/// Copy this file to `lib/demo_credentials.dart` and fill in the values.
/// `demo_credentials.dart` is gitignored — never commit real values.
///
/// The endpoint + tenant JWT come from the Terraform output and the
/// Olympus gateway's `/auth/service-tokens` flow respectively. See
/// `../../terraform/README-deploy.md` and `../../SCOTT-ACTION-REQUIRED.md`.
library;

class DemoCredentials {
  /// Olympus API gateway base URL. For the hackathon demo this is the
  /// dev gateway in olympuscloud-dev.
  static const String gatewayUrl = 'https://dev.api.olympuscloud.ai';

  /// Short-lived tenant JWT minted for the demo tenant.
  static const String tenantJwt = 'paste-demo-tenant-jwt-here';

  /// Tenant id whose Memory Bank collection this app will read/write.
  /// Switch to demo-tenant-b to prove the isolation guarantee in the demo.
  static const String tenantId = 'demo-tenant-a';

  /// User id for the demo session — any string is fine for the demo path.
  static const String userId = 'hackathon-demo-user';
}
